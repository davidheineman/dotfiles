# FAIR-specific configs
alias newfair="cloud_corp hpc login fair-sc --vpnless --et" # create / connect to login pod
alias delfair="cloud_corp hpc delete-login-pod dhei fair-sc" # delete login pod
alias claude="claude --dangerously-enable-internet-mode --dangerously-skip-permissions"
alias code="code-fb"
faircode() {
    code-fb --folder-uri vscode-remote://fb-remote+fair-sc/home/dhei/$*
}
alias fairclaude='ssh fair-sc -t '\''tmux new-session "bash -ic claude"'\'''

# Delete the MCI application
alias mci="sudo chmod 000 /Applications/MCI.app/Contents/MacOS/MCI"

# ===============================
# FAIR remote command helpers (persistent SSH session via zsh coproc)
# ===============================
# Keeps one SSH session alive per shell. We only pay the per-invocation
# `cloud_corp` cert-refresh cost (from the Match-exec block in ~/.ssh/config)
# once per shell instead of once per command. Uses zsh's `coproc` so reads
# block on a kernel pipe — no polling, no `tail -f`, no timeout.

_fair_alive() { [[ -n "$FAIR_PID" ]] && kill -0 "$FAIR_PID" 2>/dev/null }

_fairkill() {
    [[ -n "$FAIR_PID" ]] && kill "$FAIR_PID" 2>/dev/null
    unset FAIR_PID
    coproc exit 2>/dev/null
}
trap _fairkill EXIT

_fairconnect() {
    echo "fair: opening session..." >&2
    setopt local_options no_monitor    # suppress "[N] PID" job-control noise
    coproc ssh -T fair-sc "bash --login -O expand_aliases 2>&1"
    FAIR_PID=$!
    print -p "echo __FAIR_INIT_$$__"
    local line
    while IFS= read -p line; do
        [[ "$line" == "__FAIR_INIT_$$__" ]] && break
    done
}

fair() {
    if [[ $# -eq 0 ]]; then
        ssh fair-sc
        return
    fi
    _fair_alive || _fairconnect || return 1

    local m="__FAIR_${RANDOM}${RANDOM}__"
    print -p "{ $*; } 2>&1; echo ${m}_END:\$?"

    local line ec
    while IFS= read -p line; do
        if [[ "$line" == ${m}_END:* ]]; then
            ec=${line#${m}_END:}
            break
        fi
        print -r -- "$line"
    done
    return ${ec:-1}
}

fairgpu() {
    local output
    output=$(fair "python ~/fairdev/slurm/interactive.py 2>&1")
    local jobid=$(printf '%s\n' "$output" | grep -E '^[0-9]+$' | head -1)
    if [[ -z "$jobid" ]]; then
        echo "fairgpu: no running interactive job found" >&2
        printf '%s\n' "$output" >&2
        return 1
    fi
    printf '%s\n' "$output" | grep -v '^[0-9]*$' >&2
    ssh -t fair-sc "bash --login -c 'sa $jobid'"
}
